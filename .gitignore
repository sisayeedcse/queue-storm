# ─────────────────────────────────────────────────────
# .gitignore — QueueStorm Ticket Classifier
# ─────────────────────────────────────────────────────

# ── Environment Variables (NEVER commit secrets) ──────
.env
.env.*
!.env.example

# ── Python Cache ──────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual Environments ──────────────────────────────
venv/
env/
.venv/
ENV/

# ── Python Packaging ──────────────────────────────────
*.egg-info/
dist/
build/
*.egg

# ── IDE / Editor Files ────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Generated Files ────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ──────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────
.dockerignore
